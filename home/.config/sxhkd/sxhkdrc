# vim: foldenable foldmethod=marker foldlevel=1

super + q
    wmctrl -c :ACTIVE:

super + shift + p
    notify-send "Restarted polybar, picom, sxhkd and dunst" -t 3000 \
	; polybar-msg cmd restart \
	; /usr/bin/kill -s USR1 sxhkd \
	; /usr/bin/kill -s USR1 picom \
        ; dunstctl reload

super + d
    env SHELL=/bin/sh rofi -show drun -modi drun -show-icons
    # env SHELL=/bin/sh rofi -show combi -modi combi -combi-modes drun,run -show-icons

super + Tab
    rofi -show window -modi window -window-thumbnail

super + w
    "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/passmenu-rofi" \
        && notify-send "Password Copied"

super + shift + w
    as-dialogue --work-dir $HOME/proj/wifi-menu -- poetry run wmenu



# pick a [C]olor
super + b: c
    "$XDG_CONFIG_HOME/polybar/scripts/color-switch.sh"
# toggle [T]ray
super + b: t
    polybar-msg action "#tray.module_toggle"
# toggle [D]ate
super + b: d
    polybar-msg action "#date.toggle"
# [H]ide bar
super + b: h
    polybar-msg cmd toggle

super + shift + b
    "$SCRIPTS/set-bg"

# This requires these packages: rofi-emoji noto-fonts-emoji
super + e
    rofi -modi emoji -show emoji


# Desktop and Window navigation {{{

super + {bracketleft,bracketright}
    "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/ewmhwrap" go-to-{prev,next}-ws

super + shift + {bracketleft,bracketright}
    "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/ewmhwrap" send-to-{prev,next}-ws

# }}}


# Most Used Apps {{{

# TERMINAL
#     When $TERMINAL is urxvt and a shell to be run is not passed in the CLI
#     (-e <my-shell>), urxvt will try and use in this order: $SHELL,
#     getpwuid(3) or /bin/sh
super + Return
    "$TERMINAL"

# HEADS-UP!
# The `-x` flag on `wmctrl` makes it look for the string inputted in windows'
# class names, not necessarily in their titles. That's useful for non-terminal
# apps. If you ever use it with terminal apps, they will never match, because
# the class will be the host terminal's class, not the app you're looking for.
# If you're using a GUI app, then `-x` increases the *specificity* of your
# search.

super + a; h
    wmctrl -a htop \
        || "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/gui-launch" htop.desktop

super + a; m
    wmctrl -a vimpc \
        || as-dialogue vimpc

super + a; c
    wmctrl -xa galculator \
        || "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/gui-launch" galculator

super + a; w
    wmctrl -xa libreoffice-writer \
        || "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/gui-launch" libreoffice-writer.desktop

super + a; p
    wmctrl -xa pavucontrol \
        || "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/gui-launch" pavucontrol

super + a; f
    wmctrl -xa pcmanfm-qt \
        || "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/gui-launch" pcmanfm-qt.desktop

super + a; b
    wmctrl -xa librewolf \
        || "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/gui-launch" librewolf.desktop

super + a; z
    wmctrl -xa zathura \
        || "$\{XDG_CONFIG_HOME:-$HOME/.config\}/sxhkd/bin/gui-launch" org.pwmt.zathura-pdf-mupdf.desktop

# }}}

# System Menu {{{
super + m; l
    i3lock-fancy-rapid 50 10 && xset -display :0.0 dpms force off
super + m; p
    notify-send "System Information" "Powering off"
    systemctl poweroff
super + m; r
    notify-send "System Information" "Soft-rebooting"
    systemctl soft-reboot
super + m; shift + r
    notify-send "System Information" "Hard-rebooting"
    systemctl reboot
super + m; h
    notify-send "System Information" "Hybernating"
    systemctl hybernate
# super + m; s
#     notify-send "System Information" "Suspending"
#     systemctl suspend
super + m; g
    notify-send "System Information" "$(if which dm-tool >/dev/null 2>&1; then echo "Quitting to display manager"; else echo "Could not quit to display manager: 'dm-tool' is not installed"; fi)"
    # dm-tool switch-to-greeter
# }}}

# Fn Buttons {{{
Print
    flameshot gui
shift + Print
    "$SCRIPTS/screenshot"

XF86TouchpadToggle
    toggle-touchpad --notify

shift + XF86TouchpadToggle
    xset -display :0.0 dpms force off

XF86Audio{Play,Next,Prev}
    mpc {toggle,next,prev}

shift + XF86Audio{Raise,Lower}Volume
    mpc seek {+,-}00:00:05

XF86Audio{Raise,Lower}Volume
    pactl set-sink-volume @DEFAULT_SINK@ {+,-}5%

XF86AudioMute
    pactl set-sink-mute @DEFAULT_SINK@ toggle

shift + XF86AudioMute
    pkill -USR1 redshift

XF86MonBrightness{Up,Down}
    brightnessctl set 5%{+,-}

shift + XF86MonBrightness{Up,Down}
    brightnessctl set {100,0}%

# }}}

# Notifications {{{
super + n: a
    dunstctl action
super + n: q
    dunstctl close
super + n: shift + q
    dunstctl close-all
super + n: h
    dunstctl history-pop
super + n: shift + h
    dunstctl history-clear
super + n: c
    dunstctl context
super + n: t
    dunstctl set-paused toggle
# }}}


# Redshift/brightness {{{
super + r: j
    ; redshiftctl update --temperature_delta -300

super + r: k
    ; redshiftctl update --temperature_delta 300

super + r: h
    ; redshiftctl update --brightness_delta -0.05

super + r: l
    ; redshiftctl update --brightness_delta 0.05

super + r: r
    ; redshiftctl reset

super + r: c
    ; redshiftctl clear

# }}} Redshift/brightness
